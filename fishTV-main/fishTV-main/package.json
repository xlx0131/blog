    "express": "^5.2.1",
    "hls.js": "^1.6.1",
    "http-proxy-middleware": "^3.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.5.0",
    "tailwindcss-animate": "^1.0.7"
